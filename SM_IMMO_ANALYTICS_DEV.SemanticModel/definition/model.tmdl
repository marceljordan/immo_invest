model Model
	culture: en-US
	collation: Latin1_General_100_BIN2_UTF8
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["DatabaseQuery"]

annotation PBI_ProTooling = ["WebModelingEdit","CalcGroup"]

ref table dim_date
ref table fact_commission
ref table fact_dossier_adv
ref table fact_financement
ref table dim_agence_region
ref table fact_gestion_locative
ref table dim_conseiller
ref table fact_objectif_commercial
ref table dim_investisseur
ref table fact_operation_crowdfunding
ref table dim_lot_immobilier
ref table dim_programme_immobilier
ref table dim_partenaire
ref table dim_produit_investissement
ref table fact_reservation
ref table fact_revente
ref table fact_vente
ref table fact_souscription_pierre_papier
ref table dim_statut
ref table 'Calculation group'
ref table security_user_access

ref role RLS_region/agence
ref role RLS_conseillers
ref role RLS_investisseur

