			)
		formatString: 0
		lineageTag: a1b4efe9-78f8-4c24-a917-543207ab0ea5

	measure 'Financements Refusés' =
			
			CALCULATE(
			    COUNTROWS(fact_financement),
			    fact_financement[statut_financement] = "Refusé"
			)
		formatString: 0
		lineageTag: f0866272-5566-4729-a713-6e812303f923

	measure 'Lots Vendus Encore Disponibles' =
			
			CALCULATE(
			    DISTINCTCOUNT(dim_lot_immobilier[lot_key]),
			    dim_lot_immobilier[statut_lot] = "Disponible",
			    NOT ISBLANK(dim_lot_immobilier[date_vente])
			)
		formatString: 0
		lineageTag: 4c2efdf1-433a-406d-aa5f-0c6a7c0f5c51

