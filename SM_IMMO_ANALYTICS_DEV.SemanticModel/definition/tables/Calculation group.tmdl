table 'Calculation group'
	lineageTag: 2d6121f8-10f5-499e-a47e-c026a79f40db

	calculationGroup

		calculationItem 'Calculation item' = SELECTEDMEASURE()

	measure 'CA Signé' =
			
			SUM(fact_vente[montant_total_operation])
		lineageTag: 885a3495-ef9f-460d-84f6-d92e903d288f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Measure
		lineageTag: 48a9da2a-57b2-4912-93e4-1e4faf6924f1

		annotation 43dbc3e8-3a1c-4b6f-9923-b49ff7d6691c = True

	measure 'Nb Ventes' =
			
			COUNTROWS(fact_vente)
		formatString: 0
		lineageTag: bb624904-0e2a-4beb-a3ca-c0892fcfbf71

	measure 'Nb Réservations' =
			
			COUNTROWS(fact_reservation)
		formatString: 0
		lineageTag: ca8b6d2a-6f88-47ca-926b-cec6143f3b5d

	measure 'Taux Réservation Vente' =
			
			DIVIDE([Nb Ventes], [Nb Réservations])
		lineageTag: 58a99a83-ee91-4779-a95a-0ef45587e336

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Objectif CA' =
			
			SUM(fact_objectif_commercial[objectif_ca])
		lineageTag: b5f887a1-bb93-4a3a-86bf-338589d23b31

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Taux Atteinte Objectif CA' =
			
			DIVIDE([CA Signé], [Objectif CA])
		lineageTag: aa7fbb22-d1de-4557-aff5-47a54630063f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'CA Moyen Vente' =
			
			DIVIDE([CA Signé], [Nb Ventes])
		lineageTag: dd064345-250f-4e38-b521-95ea63eaa3a8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Montant Réservé' =
			
