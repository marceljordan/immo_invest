			)
		formatString: 0
		lineageTag: 95ba6e97-3aab-42b3-affb-fe11305c68ed

	measure 'Dossiers Pièces Manquantes' =
			
			CALCULATE(
			    COUNTROWS(fact_dossier_adv),
