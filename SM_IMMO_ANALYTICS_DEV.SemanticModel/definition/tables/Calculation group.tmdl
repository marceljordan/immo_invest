			)
		formatString: 0
		lineageTag: 168e5dd7-4c3c-4c23-bdab-6ef093d83ccd

	measure 'Commissions Bloquées' =
			
			CALCULATE(
			    COUNTROWS(fact_commission),
			    NOT ISBLANK(fact_commission[motif_blocage])
			)
		formatString: 0
		lineageTag: c036242d-9fe0-499c-9516-6b16aacd5abe

	measure 'Dossiers ADV Bloqués' =
			
			CALCULATE(
			    COUNTROWS(fact_dossier_adv),
