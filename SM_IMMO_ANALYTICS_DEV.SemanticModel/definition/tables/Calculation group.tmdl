	measure 'Ventes Sans Date Acte' =
			
			CALCULATE(
			    COUNTROWS(fact_vente),
			    ISBLANK(fact_vente[date_signature_acte_key])
			)
		formatString: 0
		lineageTag: e14ab785-d4cc-43b5-8e8c-033d2a9e5cfc

	measure 'Ventes Sans Investisseur' =
			
			CALCULATE(
			    COUNTROWS(fact_vente),
			    ISBLANK(fact_vente[investisseur_key])
			)
		formatString: 0
		lineageTag: 289799b2-fccb-4ede-91ef-c082fe2373cd

	measure 'Réservations Sans Lot' =
			
			CALCULATE(
			    COUNTROWS(fact_reservation),
